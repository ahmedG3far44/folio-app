generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Users {
  id              String         @id @unique @default(cuid())
  name            String
  email           String         @unique
  picture         String?
  password        String
  role            Role           @default(USER)
  resume          String?
  ExperiencesList Experiences[]
  ProjectsList    Projects[]
  SkillsList      Skills[]
  Testimonials    Testimonials[]
  ContactsList    Contacts[]
  Bio             Bio[]
  Layouts         Layouts[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

enum Role {
  USER
  ADMIN
}

model Bio {
  id        String  @id @default(cuid())
  heroImage String? @default("https://placehold.co/350x350.png")
  bio       String? @db.Text
  jobTitle  String? @default("change your current job title.... ")
  bioName   String? @default("change your name....")
  userId    Users   @relation(fields: [usersId], references: [id])
  usersId   String
}

model Experiences {
  id        String   @id @default(cuid())
  cName     String
  cLogo     String?
  position  String?
  duration  String
  role      String   @db.Text
  location  String
  userId    Users    @relation(fields: [usersId], references: [id])
  usersId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//=========================================
model Projects {
  id         String       @id @default(cuid())
  title      String
  description String       @db.Text
  thumbnail  String
  tags       Tags[]
  ImagesList ImagesList[]
  likes      Int          @default(0)
  views      Float        @default(0.0)
  source     String?
  userId     Users        @relation(fields: [usersId], references: [id])
  usersId    String
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
}

model Tags {
  id         String    @id @default(cuid())
  tagName    String
  Projects   Projects? @relation(fields: [projectsId], references: [id])
  projectsId String?
}

model ImagesList {
  id         String   @id @default(cuid())
  url        String
  projectId  Projects @relation(fields: [projectsId], references: [id])
  projectsId String
}

//=========================================

model Skills {
  id        String   @id @default(cuid())
  skillName String
  skillLogo String?
  userId    Users    @relation(fields: [usersId], references: [id])
  usersId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ====================================================
model Testimonials {
  id        String   @id @default(cuid())
  profile   String
  name      String
  feedback  String?  @db.Text
  video     String?
  position  String
  userId    Users    @relation(fields: [usersId], references: [id])
  usersId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ====================================================
model Contacts {
  id       String  @id @default(cuid())
  linkedin String?
  github   String?
  youtube  String?
  twitter  String?
  userId   Users   @relation(fields: [usersId], references: [id])
  usersId  String
}

model Layouts {
  id             String  @id @default(cuid())
  heroLayout     String? @default("1")
  expLayout      String  @default("1")
  skillsLayout   String  @default("1")
  projectsLayout String  @default("1")
  userId         Users   @relation(fields: [usersId], references: [id])
  usersId        String
}

model Theme {
  id              String  @id @default(cuid())
  backgroundColor String? @default("#121212")
  cardColor       String  @default("#1E1E1E")
  primaryText     String  @default("#64B5F6")
  secondaryText   String  @default("#BBBBBB")
  borderColor     String? @default("#2E7D32")
}
